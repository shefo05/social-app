# The deployed Express backend
NEXT_PUBLIC_API_URL=https://social-app-5f5n.onrender.com

# Socket.IO server - same origin as the API in this project's setup
NEXT_PUBLIC_SOCKET_URL=https://social-app-5f5n.onrender.com

# OAuth 2.0 Web client id from Google Cloud Console (needs to match the
# backend's GOOGLE_CLIENT_ID - both verify against the same audience)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
